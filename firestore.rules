rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to reflections collection
    match /reflections/{signalId} {
      allow read, write: if true;
    }
    
    // Allow read/write access to responses collection
    match /responses/{responseId} {
      allow read, write: if true;
    }

    // Per-Explorer notification tuning. Clients may read this, but backend
    // processes should own writes.
    match /system_config/{explorerId} {
      allow read: if true;
      allow write: if false;
    }

    // Server-side notification staging sandbox. Cloud Functions use Admin
    // credentials and bypass rules; clients should not write directly here.
    match /pending_notifications/{notificationId} {
      allow read, write: if false;
    }

  }
}

